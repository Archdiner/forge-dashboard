# Forge Backend — copy to .env and fill in values

# Required: Google Gemini API key for LLM hypothesis generation
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Backend URL (used by agents to call claim/publish endpoints)
FORGE_API_URL=http://localhost:8000

# CORS allowed origins (comma-separated). Add your frontend domain in production.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: override agent defaults when running run_demo.py
# AGENT_ID=agent-1
# AGENT_NAME=Agent Alpha
# TEMPLATE_ID=landing-page-cro
# EXPERIMENT_DELAY=3.0
